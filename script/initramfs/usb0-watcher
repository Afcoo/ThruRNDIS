#!/bin/sh

BB=/usr/bin/busybox
PATH=/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin:/usr/local/sbin
export PATH

RNDIS_IFACE=${RTPVM_RNDIS_IFACE:-usb0}
WATCH_INTERVAL_SECONDS=${RTPVM_USB0_WATCH_INTERVAL_SECONDS:-2}
GATEWAY_SCRIPT=${RTPVM_GATEWAY_SCRIPT:-/usr/local/sbin/wg0-usb0-gateway}

log() {
    echo "rtpvm-usb0-watcher: $*" >/dev/kmsg 2>/dev/null || true
}

log_console() {
    log "$*"
    if [ -c /dev/console ]; then
        echo "rtpvm-usb0-watcher: $*" >/dev/console 2>/dev/null || true
    else
        echo "rtpvm-usb0-watcher: $*" 2>/dev/null || true
    fi
}

last_present=""
last_ready=""

log_console "started; watching $RNDIS_IFACE every ${WATCH_INTERVAL_SECONDS}s"

while true; do
    if [ -e "/sys/class/net/$RNDIS_IFACE" ]; then
        if [ "$last_present" != "present" ]; then
            log_console "$RNDIS_IFACE appeared"
            last_present="present"
            last_ready=""
        fi

        if "$GATEWAY_SCRIPT" status >/dev/null 2>&1; then
            if [ "$last_ready" != "ready" ]; then
                log_console "$RNDIS_IFACE gateway is ready"
            fi
            last_ready="ready"
        else
            case "$last_ready" in
                ready)
                    log_console "$RNDIS_IFACE gateway state changed; reconfiguring"
                    ;;
                configuring|failed|incomplete)
                    :
                    ;;
                *)
                    log_console "$RNDIS_IFACE gateway is not ready; configuring"
                    ;;
            esac

            last_ready="configuring"
            if "$GATEWAY_SCRIPT" up; then
                if "$GATEWAY_SCRIPT" status >/dev/null 2>&1; then
                    log_console "$RNDIS_IFACE gateway configured"
                    last_ready="ready"
                else
                    log_console "$RNDIS_IFACE gateway configuration completed but status is incomplete"
                    last_ready="incomplete"
                fi
            else
                log_console "$RNDIS_IFACE gateway configuration failed; will retry"
                last_ready="failed"
            fi
        fi
    else
        [ -x /sbin/mdev ] && /sbin/mdev -s 2>/dev/null || true
        if [ "$last_present" != "absent" ]; then
            log_console "$RNDIS_IFACE is absent; clearing gateway state"
            "$GATEWAY_SCRIPT" down || true
            last_present="absent"
            last_ready="absent"
        fi
    fi

    $BB sleep "$WATCH_INTERVAL_SECONDS"
done

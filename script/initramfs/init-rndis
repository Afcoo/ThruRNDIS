#!/bin/sh

BB=/usr/bin/busybox
PATH=/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin:/usr/local/sbin
export PATH

log() {
    echo "thrurndis-rndis-init: $*" >/dev/kmsg 2>/dev/null || true
}

log_console() {
    log "$*"
    if [ -c /dev/console ]; then
        echo "thrurndis-rndis-init: $*" >/dev/console 2>/dev/null || true
    else
        echo "thrurndis-rndis-init: $*" 2>/dev/null || true
    fi
}

run_with_timeout() {
    timeout_seconds=$1
    shift

    "$@" &
    child_pid=$!
    (
        $BB sleep "$timeout_seconds"
        kill "$child_pid" 2>/dev/null || true
        $BB sleep 1
        kill -9 "$child_pid" 2>/dev/null || true
    ) &
    watchdog_pid=$!

    wait "$child_pid"
    rc=$?
    kill "$watchdog_pid" 2>/dev/null || true
    wait "$watchdog_pid" 2>/dev/null || true

    case "$rc" in
        137|143) return 124 ;;
        *) return "$rc" ;;
    esac
}

load_module() {
    module=$1
    timeout_seconds=${2:-4}
    [ -n "$module" ] || return 0

    run_with_timeout "$timeout_seconds" /sbin/modprobe -q "$module" 2>/tmp/modprobe.err
    rc=$?
    if [ "$rc" -eq 0 ]; then
        log_console "loaded module $module"
        return 0
    fi

    error=$($BB cat /tmp/modprobe.err 2>/dev/null || true)
    log_console "failed to load module $module rc=$rc ${error}"
    return "$rc"
}

log_console "preparing RNDIS USB modules"
for module in xhci-hcd xhci-pci usbnet cdc_ether cdc_subset rndis_host; do
    load_module "$module" 4 || true
done

[ -x /sbin/mdev ] && /sbin/mdev -s 2>/dev/null || true
log_console "RNDIS USB module preparation finished"
exit 0

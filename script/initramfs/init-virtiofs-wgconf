#!/bin/sh

BB=/usr/bin/busybox
PATH=/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin:/usr/local/sbin
export PATH

SHARE_TAG=rtpvm-wireguard
SHARE_MOUNT=/run/rtpvm-wireguard
SOURCE_CONFIG="$SHARE_MOUNT/wg0.conf"
MOUNT_TIMEOUT_SECONDS=${RTPVM_WIREGUARD_MOUNT_TIMEOUT_SECONDS:-8}

log() {
    echo "rtpvm-wireguard-config: $*" >/dev/kmsg 2>/dev/null || true
}

log_console() {
    log "$*"
    if [ -c /dev/console ]; then
        echo "rtpvm-wireguard-config: $*" >/dev/console 2>/dev/null || true
    else
        echo "rtpvm-wireguard-config: $*" >&2
    fi
}

run_with_timeout() {
    timeout_seconds=$1
    shift

    "$@" &
    child_pid=$!
    (
        $BB sleep "$timeout_seconds"
        kill "$child_pid" 2>/dev/null || true
        $BB sleep 1
        kill -9 "$child_pid" 2>/dev/null || true
    ) &
    watchdog_pid=$!

    wait "$child_pid"
    rc=$?
    kill "$watchdog_pid" 2>/dev/null || true
    wait "$watchdog_pid" 2>/dev/null || true

    case "$rc" in
        137|143) return 124 ;;
        *) return "$rc" ;;
    esac
}

fail() {
    log_console "$*"
    exit 1
}

log_console "mounting WireGuard configuration share"

run_with_timeout "$MOUNT_TIMEOUT_SECONDS" /sbin/modprobe -q virtiofs 2>/tmp/rtpvm-virtiofs-modprobe.err
rc=$?
if [ "$rc" -ne 0 ]; then
    output=$($BB cat /tmp/rtpvm-virtiofs-modprobe.err 2>/dev/null || true)
    fail "failed to load virtiofs module rc=$rc ${output}"
fi

$BB mkdir -p "$SHARE_MOUNT" || fail "failed to create WireGuard share mount point"
$BB chmod 0700 "$SHARE_MOUNT" || fail "failed to secure WireGuard share mount point"

run_with_timeout "$MOUNT_TIMEOUT_SECONDS" \
    $BB mount -t virtiofs -o ro,nosuid,nodev,noexec "$SHARE_TAG" "$SHARE_MOUNT" \
    2>/tmp/rtpvm-virtiofs-mount.err
rc=$?
if [ "$rc" -ne 0 ]; then
    output=$($BB cat /tmp/rtpvm-virtiofs-mount.err 2>/dev/null || true)
    fail "failed to mount $SHARE_TAG read-only rc=$rc ${output}"
fi

if [ ! -f "$SOURCE_CONFIG" ]; then
    fail "WireGuard configuration $SOURCE_CONFIG not found"
fi

if [ ! -s "$SOURCE_CONFIG" ]; then
    fail "WireGuard configuration is empty"
fi

log_console "mounted read-only WireGuard configuration at $SOURCE_CONFIG"
exit 0

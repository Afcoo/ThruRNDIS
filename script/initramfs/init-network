#!/bin/sh

BB=/usr/bin/busybox
PATH=/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin:/usr/local/sbin
export PATH
NAT_WAIT_SECONDS=${RTPVM_NAT_WAIT_SECONDS:-8}
NAT_DHCP_ATTEMPTS=${RTPVM_NAT_DHCP_ATTEMPTS:-5}
NAT_DHCP_TIMEOUT_SECONDS=${RTPVM_NAT_DHCP_TIMEOUT_SECONDS:-2}
NAT_DHCP_TOTAL_TIMEOUT_SECONDS=${RTPVM_NAT_DHCP_TOTAL_TIMEOUT_SECONDS:-16}
WG_START_TIMEOUT_SECONDS=${RTPVM_WG_START_TIMEOUT_SECONDS:-16}

log() {
    echo "rtpvm-net: $*" >/dev/kmsg 2>/dev/null || true
}

log_console() {
    log "$*"
    if [ -c /dev/console ]; then
        echo "rtpvm-net: $*" >/dev/console 2>/dev/null || true
    else
        echo "rtpvm-net: $*" 2>/dev/null || true
    fi
}

run_with_timeout() {
    timeout_seconds=$1
    shift

    "$@" &
    child_pid=$!
    (
        $BB sleep "$timeout_seconds"
        kill "$child_pid" 2>/dev/null || true
        $BB sleep 1
        kill -9 "$child_pid" 2>/dev/null || true
    ) &
    watchdog_pid=$!

    wait "$child_pid"
    rc=$?
    kill "$watchdog_pid" 2>/dev/null || true
    wait "$watchdog_pid" 2>/dev/null || true

    case "$rc" in
        137|143) return 124 ;;
        *) return "$rc" ;;
    esac
}

load_module() {
    module=$1
    timeout_seconds=${2:-4}
    [ -n "$module" ] || return 0

    run_with_timeout "$timeout_seconds" /sbin/modprobe -q "$module" 2>/tmp/modprobe.err
    rc=$?
    if [ "$rc" -eq 0 ]; then
        log_console "loaded module $module"
        return 0
    fi

    error=$($BB cat /tmp/modprobe.err 2>/dev/null || true)
    log_console "failed to load module $module rc=$rc ${error}"
    return "$rc"
}

wait_for_interface() {
    iface=$1
    timeout_seconds=${2:-8}
    elapsed=0

    while [ "$elapsed" -lt "$timeout_seconds" ]; do
        [ -e "/sys/class/net/$iface" ] && return 0
        [ -x /sbin/mdev ] && /sbin/mdev -s 2>/dev/null || true
        $BB sleep 1
        elapsed=$((elapsed + 1))
    done

    return 1
}

interface_ipv4_cidr() {
    iface=$1
    ip -4 -o addr show dev "$iface" 2>/dev/null | $BB awk '{ print $4 }' | $BB head -n 1
}

interface_ipv4_address() {
    cidr=$(interface_ipv4_cidr "$1")
    [ -n "$cidr" ] || return 0
    printf '%s' "${cidr%%/*}"
}

interface_default_gateway() {
    iface=$1
    ip -4 route show default dev "$iface" 2>/dev/null | $BB awk '
        $1 == "default" {
            for (i = 1; i <= NF; i++) {
                if ($i == "via" && i < NF) {
                    print $(i + 1)
                    exit
                }
            }
        }
    '
}

wireguard_listen_port() {
    config=$1
    [ -f "$config" ] || return 1

    port=$($BB awk '
        function trim(value) {
            gsub(/^[[:space:]]+/, "", value)
            gsub(/[[:space:]]+$/, "", value)
            return value
        }

        {
            line = $0
            sub(/[;#].*$/, "", line)

            if (line ~ /^[[:space:]]*\[/) {
                section = line
                sub(/^[[:space:]]*\[/, "", section)
                sub(/\][[:space:]]*$/, "", section)
                section = trim(section)
                next
            }

            if (section == "Interface" && line ~ /^[[:space:]]*ListenPort[[:space:]]*=/) {
                sub(/^[^=]*=/, "", line)
                print trim(line)
                exit
            }
        }
    ' "$config")

    case "$port" in
        ''|*[!0-9]*) return 1 ;;
    esac

    if [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
        return 1
    fi

    printf '%s' "$port"
}

configure_ipv4_dhcp() {
    iface=$1
    label=$2
    timeout_seconds=${3:-8}
    attempts=${4:-5}
    packet_timeout_seconds=${5:-2}
    total_timeout_seconds=${6:-16}
    udhcpc_log="/tmp/udhcpc-$iface.log"
    udhcpc_script=""

    if ! wait_for_interface "$iface" "$timeout_seconds"; then
        log_console "$label $iface not found; skipping IPv4 DHCP"
        return 1
    fi

    log_console "requesting IPv4 DHCP on $label $iface"
    ip link set dev "$iface" up 2>/dev/null || $BB ifconfig "$iface" up 2>/dev/null || true

    if [ -f /usr/share/udhcpc/default.script ]; then
        udhcpc_script="-s /usr/share/udhcpc/default.script"
    fi

    run_with_timeout "$total_timeout_seconds" \
        udhcpc -i "$iface" -q -n -t "$attempts" -T "$packet_timeout_seconds" $udhcpc_script \
        >"$udhcpc_log" 2>&1
    rc=$?
    if [ "$rc" -eq 0 ]; then
        ipv4=$(interface_ipv4_cidr "$iface")
        if [ -n "$ipv4" ]; then
            log_console "$label $iface IPv4 $ipv4"
            return 0
        fi

        log_console "$label $iface DHCP completed without visible IPv4 address"
        return 1
    fi

    output=$($BB tail -n 3 "$udhcpc_log" 2>/dev/null | $BB tr '\n' ' ' || true)
    log_console "$label $iface DHCP failed rc=$rc ${output}"
    return 1
}

load_nat_modules() {
    for module in virtio_pci virtio_mmio virtio_net af_packet; do
        load_module "$module" 4 || true
    done
}

configure_nat_ipv4() {
    iface=${1:-eth0}
    listen_port=${2:-}
    load_nat_modules
    if configure_ipv4_dhcp "$iface" "NAT interface" "$NAT_WAIT_SECONDS" \
        "$NAT_DHCP_ATTEMPTS" "$NAT_DHCP_TIMEOUT_SECONDS" "$NAT_DHCP_TOTAL_TIMEOUT_SECONDS"; then
        endpoint_ipv4=$(interface_ipv4_address "$iface")
        if [ -n "$endpoint_ipv4" ] && [ -n "$listen_port" ]; then
            log_console "RTPVM_WG_ENDPOINT=$endpoint_ipv4:$listen_port"
        elif [ -n "$endpoint_ipv4" ]; then
            log_console "WireGuard ListenPort is unavailable; endpoint marker not emitted"
        fi
        return 0
    fi

    return 0
}

load_wireguard_modules() {
    load_module wireguard 4 || true
}

start_wireguard() {
    iface=${1:-wg0}
    config=${2:-"/run/rtpvm-wireguard/$iface.conf"}
    wg_quick_log="/tmp/wg-quick-$iface.log"

    if [ ! -f "$config" ]; then
        log_console "WireGuard config $config not found; skipping $iface"
        return 0
    fi

    if ! command -v wg-quick >/dev/null 2>&1; then
        log_console "wg-quick not found; skipping $iface"
        return 0
    fi

    log_console "starting WireGuard interface $iface"
    load_wireguard_modules
    run_with_timeout "$WG_START_TIMEOUT_SECONDS" wg-quick up "$config" >"$wg_quick_log" 2>&1
    rc=$?
    if [ "$rc" -eq 0 ]; then
        log_console "WireGuard interface $iface started"
        return 0
    fi

    output=$($BB tail -n 5 "$wg_quick_log" 2>/dev/null | $BB tr '\n' ' ' || true)
    log_console "WireGuard interface $iface failed rc=$rc ${output}"
    return 0
}

log_console "starting RTPVM network one-shot"
wireguard_config=/run/rtpvm-wireguard/wg0.conf
listen_port=$(wireguard_listen_port "$wireguard_config" 2>/dev/null || true)
configure_nat_ipv4 eth0 "$listen_port" || true
start_wireguard wg0 "$wireguard_config" || true
log_console "RTPVM network one-shot finished; usb0-watcher handles RNDIS routing"
exit 0
